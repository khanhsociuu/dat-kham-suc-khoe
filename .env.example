# ===== Cấu hình server =====
PORT=3000
SESSION_SECRET=doi-chuoi-bi-mat-nay-truoc-khi-dua-len-production

# ===== Cấu hình SMTP để gửi EMAIL THẬT (nhắc lịch / xác nhận đặt lịch) =====
# Nếu để trống, hệ thống sẽ tự chuyển sang "chế độ mô phỏng": chỉ ghi log, KHÔNG gửi email thật.
#
# Hướng dẫn lấy App Password của Gmail (miễn phí):
# 1. Bật xác minh 2 bước cho tài khoản Gmail: https://myaccount.google.com/security
# 2. Vào https://myaccount.google.com/apppasswords -> tạo mật khẩu ứng dụng (App Password)
# 3. Dán mật khẩu 16 ký tự đó vào SMTP_PASS bên dưới (KHÔNG dùng mật khẩu Gmail thường)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
